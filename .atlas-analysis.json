  "keyFeatures": [
    "ANTLR4 grammar-based lexical and syntax analysis",
    "Support for arithmetic expressions with operator precedence",
    "Conditional control flow (if-else statements)",
    "Variable declarations with type checking (int, float, bool)",
    "Symbol table management for semantic analysis",
    "Visitor pattern implementation for AST traversal",
    "Relational and logical operators",
    "Interactive file selection GUI"
  ],
  "publicApiSurface": [
    "ExpresionesLexer - Tokenizes input source code",
    "ExpresionesParser - Parses tokens into AST",
    "ExpresionesVisitor - Base visitor interface for AST traversal",
    "Visitor - Custom visitor implementation with semantic analysis",
    "Simbolo - Symbol table entry class",
    "visitProg() - Program entry point visitor method",
    "visitInstrDecl() - Variable declaration visitor",
    "visitInstrAsig() - Assignment statement visitor",
    "visitInstrIf() - Conditional statement visitor",
    "visitAritmetica() - Arithmetic expression evaluator",
    "visitRelacional() - Relational expression evaluator",
    "visitLogica() - Logical expression evaluator"
  ]
